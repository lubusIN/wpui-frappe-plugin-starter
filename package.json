{
  "name": "wpui-frappe-plugin-starter",
  "version": "0.1.0",
  "description": "WordPress plugin starter / template repository for WP Frappe Data Store with @wordpress/boot and @wordpress/build",
  "license": "MIT",
  "private": true,
  "files": [
    "build/**/*.php",
    "build/**/*.min.js",
    "build/pages/*/loader.js",
    "includes/",
    "README.md",
    "readme.txt",
    "uninstall.php",
    "wpui-frappe-plugin-starter.php"
  ],
  "workspaces": [
    "packages/*",
    "routes/*"
  ],
  "scripts": {
    "build": "wp-build",
    "postbuild": "node ./scripts/postbuild.mjs",
    "dev": "wp-build --watch",
    "format": "wp-scripts format packages/common/src packages/init/src routes/*/stage.tsx",
    "lint:js": "wp-scripts lint-js packages/common/src packages/init/src routes/*/stage.tsx",
    "lint:style": "wp-scripts lint-style 'packages/**/*.scss'",
    "typecheck": "tsc --noEmit",
    "lint:php": "php -l wpui-frappe-plugin-starter.php && php -l includes/class-plugin.php && php -l includes/class-rest-proxy.php && php -l uninstall.php",
    "check": "npm run lint:js && npm run lint:style && npm run typecheck && npm run lint:php && npm run build",
    "playground": "wp-playground-cli start --blueprint=_playground/blueprint-local.json",
    "plugin-zip": "npm run check && wp-scripts plugin-zip"
  },
  "wpPlugin": {
    "name": "wp_frappe_data_store",
    "scriptGlobal": "wpFrappeDataStore",
    "packageNamespace": "wp-frappe-data-store",
    "handlePrefix": "wp-frappe-data-store",
    "pages": [
      {
        "id": "frappe-data-store",
        "init": [
          "@wp-frappe-data-store/init"
        ]
      }
    ]
  },
  "dependencies": {
    "@babel/core": "^7.24.0",
    "@lubusin/wp-frappe-data-store": "^0.1.0",
    "@wordpress/admin-ui": "^2.5.0",
    "@wordpress/boot": "latest",
    "@wordpress/components": "^36.0.0",
    "@wordpress/data": "latest",
    "@wordpress/dataviews": "^17.0.0",
    "@wordpress/element": "^8.1.0",
    "@wordpress/i18n": "latest",
    "@wordpress/icons": "^15.0.0",
    "@wordpress/notices": "latest",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@wordpress/build": "latest",
    "@wordpress/scripts": "latest",
    "@wp-playground/cli": "latest",
    "typescript": "latest"
  }
}

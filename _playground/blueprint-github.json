{
    "$schema": "https://playground.wordpress.net/blueprint-schema.json",
    "landingPage": "/wp-admin/admin.php?page=frappe-data-store",
    "preferredVersions": {
        "php": "8.2",
        "wp": "latest"
    },
    "features": {
        "networking": true
    },
    "steps": [
        {
            "step": "login",
        },
        {
            "step": "updateUserMeta",
            "meta": {
                "admin_color": "modern",
                "show_welcome_panel": 0
            },
            "userId": 1
        },
        {
            "step": "setSiteOptions",
            "options": {
                "blogname": "WPUI Frappe Plugin Starter"
            }
        },
        {
            "step": "installPlugin",
            "pluginData": {
                "resource": "git:directory",
                "url": "https://github.com/lubusIN/wpui-frappe-plugin-starter.git",
                "ref": "playground",
                "refType": "branch"
            },
            "options": {
                "targetFolderName": "wpui-frappe-plugin-starter",
                "activate": true
            }
        }
    ]
}

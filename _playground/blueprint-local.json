{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/wp-admin/admin.php?page=frappe-data-store",
  "preferredVersions": {
    "php": "8.2",
    "wp": "latest"
  },
  "features": {
    "networking": true
  },
  "steps": [
    {
      "step": "defineWpConfigConsts",
      "consts": {
        "WP_ENVIRONMENT_TYPE": "local",
        "WPUI_FRAPPE_ALLOW_LOCAL": true,
        "WPUI_FRAPPE_ALLOW_INSECURE_TLS": true
      }
    },
    {
      "step": "login"
    },
    {
      "step": "activatePlugin",
      "pluginPath": "wpui-frappe-plugin-starter/wpui-frappe-plugin-starter.php"
    }
  ]
}
